# Copy this file to ".env" and fill in your real values.
# The .env file is gitignored — NEVER commit real credentials.

# Neon Postgres connection string.
# Get this from https://neon.tech → your project → "Connection string".
# Make sure it ends with ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Port the API server listens on
PORT=4000

# Where the React frontend runs (for CORS + Socket.io). Comma-separate multiple.
CLIENT_ORIGIN="http://localhost:5173"

# How long a reservation is held before it expires, in seconds
RESERVATION_TTL_SECONDS=60

# How often the background sweeper checks for expired reservations, in milliseconds
SWEEPER_INTERVAL_MS=3000
